---
import { Image } from 'astro:assets';
import foodImg from '../assets/images/food.png';
---

<section id="menu" class="py-24 bg-brand-dark text-brand-cream relative">
  {/* Subtle texture/pattern overlay (simulated with CSS) */}
  <div
    class="absolute inset-0 opacity-5 bg-[radial-gradient(circle_at_center,var(--color-brand-gold)_0%,transparent_100%)] bg-size-[20px_20px]"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-16">
      <h2
        class="text-brand-gold text-sm uppercase tracking-[0.2em] font-bold mb-4"
      >
        Notre Sécarte
      </h2>
      <h3 class="text-4xl md:text-5xl font-serif text-brand-cream">
        L'Art de la Brasserie
      </h3>
      <div class="mt-6 flex justify-center">
        <div class="w-16 h-px bg-brand-gold/50"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      {/* Plats Traditionnels */}
      <div
        class="bg-brand-dark-wood/40 p-8 md:p-12 border border-brand-gold/10 rounded-sm shadow-2xl backdrop-blur-sm"
      >
        <h4
          class="text-3xl font-serif text-brand-gold mb-12 text-center border-b border-brand-gold/20 pb-4"
        >
          Plats de Tradition
        </h4>

        <div class="space-y-8">
          <div class="group cursor-pointer">
            <div class="flex justify-between items-baseline mb-2">
              <h5
                class="text-xl font-serif group-hover:text-brand-gold transition-colors"
              >
                L'Authentique Œuf Mayonnaise
              </h5>
              <div
                class="grow border-b border-dotted border-brand-cream/20 mx-4"
              >
              </div>
              <span class="text-lg font-serif">9€</span>
            </div>
            <p class="text-brand-cream/60 font-light text-sm">
              Recette de grand-mère, mayo à la moutarde ancienne.
            </p>
          </div>

          <div class="group cursor-pointer">
            <div class="flex justify-between items-baseline mb-2">
              <h5
                class="text-xl font-serif group-hover:text-brand-gold transition-colors"
              >
                Vol-au-vent Financière
              </h5>
              <div
                class="grow border-b border-dotted border-brand-cream/20 mx-4"
              >
              </div>
              <span class="text-lg font-serif">28€</span>
            </div>
            <p class="text-brand-cream/60 font-light text-sm">
              Feuilletage maison, ris de veau, champignons de Paris, quenelles.
            </p>
          </div>

          <div class="group cursor-pointer">
            <div class="flex justify-between items-baseline mb-2">
              <h5
                class="text-xl font-serif group-hover:text-brand-gold transition-colors"
              >
                Pièce de Bœuf au Poivre Vert
              </h5>
              <div
                class="grow border-b border-dotted border-brand-cream/20 mx-4"
              >
              </div>
              <span class="text-lg font-serif">34€</span>
            </div>
            <p class="text-brand-cream/60 font-light text-sm">
              Filet de bœuf, sauce crémée au poivre, frites maison au couteau.
            </p>
          </div>

          <div class="group cursor-pointer">
            <div class="flex justify-between items-baseline mb-2">
              <h5
                class="text-xl font-serif group-hover:text-brand-gold transition-colors"
              >
                Sole Meunière Entière
              </h5>
              <div
                class="grow border-b border-dotted border-brand-cream/20 mx-4"
              >
              </div>
              <span class="text-lg font-serif">48€</span>
            </div>
            <p class="text-brand-cream/60 font-light text-sm">
              Pommes vapeur, beurre noisette, citron et persil plat.
            </p>
          </div>
        </div>
      </div>

      {/* Image / Vins */}
      <div class="flex flex-col gap-8">
        <div
          class="h-64 rounded-sm overflow-hidden border border-brand-gold/10 relative group"
        >
          <Image
            src={foodImg}
            alt="Plat traditionnel brasserie"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
          <div
            class="absolute inset-0 bg-brand-dark/20 group-hover:bg-transparent transition-colors duration-500"
          >
          </div>
        </div>

        <div
          class="bg-brand-bordeaux-light/10 p-8 border border-brand-bordeaux/20 rounded-sm grow"
        >
          <h4 class="text-2xl font-serif text-brand-cream mb-6 text-center">
            La Cave & Les Bières
          </h4>
          <p
            class="text-brand-cream/80 text-center font-light leading-relaxed mb-6"
          >
            Découvrez notre sélection confidentielle de vins de propriétaires,
            de grands crus classés et de bières ambrées à la pression qui font
            la renommée de notre bel établissement.
          </p>
          <div class="text-center">
            <button
              class="text-brand-gold uppercase tracking-widest text-sm font-bold hover:text-brand-cream transition-colors border-b border-brand-gold pb-1 inline-block"
            >
              Télécharger la carte des vins (PDF)
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
