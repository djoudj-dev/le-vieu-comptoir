---
// Reservation component
---

<section id="reservation" class="py-24 bg-brand-cream relative">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div
      class="bg-brand-dark-wood p-8 md:p-12 rounded-sm shadow-2xl border border-brand-gold/20 relative overflow-hidden"
    >
      {/* Decorative inner border */}
      <div
        class="absolute inset-4 border border-brand-gold/10 rounded-sm pointer-events-none"
      >
      </div>

      <div class="relative z-10">
        <div class="text-center mb-10">
          <h2
            class="text-brand-gold text-sm uppercase tracking-[0.2em] font-bold mb-4"
          >
            Réserver une table
          </h2>
          <h3 class="text-3xl md:text-5xl font-serif text-brand-cream">
            Votre moment au Vieux Comptoir
          </h3>
        </div>

        <form class="space-y-6" id="reservation-form">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label
                for="date"
                class="block text-brand-cream text-sm mb-2 font-medium"
                >Date de réservation</label
              >
              <input
                type="date"
                id="date"
                class="w-full bg-brand-dark/50 border border-brand-gold/30 rounded-sm px-4 py-3 text-brand-cream focus:outline-none focus:border-brand-gold transition-colors font-sans"
              />
            </div>

            <div>
              <label
                for="time"
                class="block text-brand-cream text-sm mb-2 font-medium"
                >Heure</label
              >
              <select
                id="time"
                class="w-full bg-brand-dark/50 border border-brand-gold/30 rounded-sm px-4 py-3 text-brand-cream focus:outline-none focus:border-brand-gold transition-colors appearance-none font-sans"
              >
                <option value="">Sélectionnez une heure</option>
                <option value="19:00">19:00 - Dîner</option>
                <option value="19:30">19:30 - Dîner</option>
                <option value="20:00">20:00 - Dîner</option>
                <option value="20:30">20:30 - Dîner</option>
                <option value="21:00">21:00 - Dîner</option>
              </select>
            </div>

            <div>
              <label
                for="guests"
                class="block text-brand-cream text-sm mb-2 font-medium"
                >Nombre de convives</label
              >
              <select
                id="guests"
                class="w-full bg-brand-dark/50 border border-brand-gold/30 rounded-sm px-4 py-3 text-brand-cream focus:outline-none focus:border-brand-gold transition-colors appearance-none font-sans"
              >
                <option value="1">1 Personne</option>
                <option value="2" selected>2 Personnes</option>
                <option value="3">3 Personnes</option>
                <option value="4">4 Personnes</option>
                <option value="5">5 Personnes</option>
                <option value="6">6 Personnes</option>
                <option value="more">Plus de 6 (Contactez-nous)</option>
              </select>
            </div>

            <div>
              <label
                for="name"
                class="block text-brand-cream text-sm mb-2 font-medium"
                >Nom de la réservation</label
              >
              <input
                type="text"
                id="name"
                placeholder="Votre nom"
                class="w-full bg-brand-dark/50 border border-brand-gold/30 rounded-sm px-4 py-3 text-brand-cream focus:outline-none focus:border-brand-gold transition-colors font-sans"
              />
            </div>
          </div>

          <div class="mt-8 text-center pt-6">
            <button
              type="submit"
              class="bg-brand-bordeaux hover:bg-brand-bordeaux-light text-brand-cream px-10 py-4 rounded-sm transition-colors text-sm uppercase tracking-widest font-bold border border-brand-bordeaux-light w-full md:w-auto shadow-lg hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-brand-cream focus:ring-offset-2 focus:ring-offset-brand-dark-wood"
            >
              Confirmer la réservation
            </button>
            <p class="text-brand-cream/80 text-xs mt-4 font-light">
              Pour toute réservation de plus de 6 personnes ou privatisation du
              Fumoir, merci de nous contacter directement au 01 XX XX XX XX.
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

{/* Redirect Modal */}
<div
  id="thefork-modal"
  class="fixed inset-0 z-50 flex items-center justify-center bg-brand-dark/80 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
>
  <div
    class="bg-brand-cream p-8 max-w-md w-full mx-4 rounded-sm shadow-2xl border border-brand-gold/30 transform scale-95 transition-transform duration-300 text-center"
    id="thefork-modal-content"
  >
    <div
      class="w-16 h-16 mx-auto bg-brand-dark-wood rounded-full flex items-center justify-center mb-6 border-2 border-brand-gold"
    >
      <svg
        class="w-8 h-8 text-brand-gold"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
      </svg>
    </div>

    <h3 class="text-2xl font-serif text-brand-dark mb-4">
      Redirection en cours...
    </h3>

    <p class="text-brand-dark/80 font-light mb-8 font-sans">
      Pour vous garantir le meilleur service, nos réservations s'effectuent via
      la plateforme partenaire <strong class="text-brand-bordeaux"
        >The Fork</strong
      >.
      <br /><br />
      Vous allez y être redirigé dans un instant.
    </p>

    <div class="flex justify-center gap-4">
      <button
        id="close-modal-btn"
        class="px-6 py-2 border border-brand-dark/20 text-brand-dark/60 hover:text-brand-dark hover:border-brand-dark transition-colors rounded-sm uppercase tracking-wider text-xs font-bold"
      >
        Annuler
      </button>
      <a
        href="https://www.thefork.fr/"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-2 bg-brand-bordeaux text-brand-cream hover:bg-brand-bordeaux-light transition-colors rounded-sm uppercase tracking-wider text-xs font-bold"
        id="continue-btn"
      >
        Continuer
      </a>
    </div>
  </div>
</div>

<script>
  // Script to handle the modal
  const form = document.getElementById('reservation-form');
  const modal = document.getElementById('thefork-modal');
  const modalContent = document.getElementById('thefork-modal-content');
  const closeBtn = document.getElementById('close-modal-btn');
  const continueBtn = document.getElementById('continue-btn');

  // Open modal on form submit instead of submitting
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (modal && modalContent) {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modalContent.classList.remove('scale-95');
      modalContent.classList.add('scale-100');
    }
  });

  // Close modal functions
  const closeModal = () => {
    if (modal && modalContent) {
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalContent.classList.remove('scale-100');
      modalContent.classList.add('scale-95');
    }
  };

  closeBtn?.addEventListener('click', closeModal);
  continueBtn?.addEventListener('click', closeModal); // closes our modal as it opens new tab

  // Close when clicking outside
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
</script>
