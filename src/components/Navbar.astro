---
// Navbar component
---

<header
  class="fixed w-full z-50 transition-all duration-300 bg-brand-dark-wood/95 backdrop-blur-sm shadow-md border-b border-brand-gold/20"
  id="navbar"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="shrink-0 flex items-center">
        <a
          href="#"
          class="font-serif text-2xl font-bold text-brand-gold tracking-wider"
        >
          Le Vieux Comptoir
        </a>
      </div>

      {/* Desktop Menu */}
      <nav class="hidden md:flex space-x-8 items-center">
        <a
          href="#about"
          class="text-brand-cream hover:text-brand-gold transition-colors text-sm uppercase tracking-widest font-medium"
          >L'Établissement</a
        >
        <a
          href="#menu"
          class="text-brand-cream hover:text-brand-gold transition-colors text-sm uppercase tracking-widest font-medium"
          >La Carte</a
        >
        <a
          href="#cigar-lounge"
          class="text-brand-cream hover:text-brand-gold transition-colors text-sm uppercase tracking-widest font-medium"
          >Le Fumoir</a
        >
        <a
          href="#contact"
          class="text-brand-cream hover:text-brand-gold transition-colors text-sm uppercase tracking-widest font-medium"
          >Contact</a
        >
        <a
          href="#reservation"
          class="bg-brand-bordeaux hover:bg-brand-bordeaux-light text-brand-cream px-6 py-2 rounded-sm transition-colors text-sm uppercase tracking-widest font-bold border border-brand-bordeaux-light"
        >
          Réserver
        </a>
      </nav>

      {/* Mobile menu button */}
      <div class="md:hidden flex items-center">
        <button
          type="button"
          aria-label="Ouvrir le menu principal"
          class="text-brand-gold hover:text-brand-cream focus:outline-none focus:ring-2 focus:ring-brand-gold rounded-sm p-1"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
  // Simple scroll effect for navbar
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (window.scrollY > 50) {
      navbar?.classList.add('shadow-lg');
    } else {
      navbar?.classList.remove('shadow-lg');
    }
  });
</script>
